#!/usr/bin/env bash
# Run a cmux "open" command (markdown/browser/...), which always opens a split,
# then move the resulting surface into the calling pane so it becomes a TAB.
#
# Usage: cmux-open-tab <cmux-open-subcommand> [args...]
#   e.g. cmux-open-tab browser open https://example.com
#        cmux-open-tab markdown open plan.md
#
# Set CMUX_OPEN_TAB_LABEL to customize the program name in error messages.
set -uo pipefail

prog="${CMUX_OPEN_TAB_LABEL:-cmux-open-tab}"

if [[ -z "${CMUX_SURFACE_ID:-}" ]]; then
    echo "$prog: not running inside cmux" >&2
    exit 1
fi

if [[ $# -eq 0 ]]; then
    echo "usage: cmux-open-tab <cmux-open-subcommand> [args...]" >&2
    exit 2
fi

# The calling terminal's pane (env is inherited, so this works from scripts too).
pane="$(cmux identify 2>/dev/null \
    | awk '/"caller"/{f=1} f&&/pane_ref/{gsub(/.*: "|".*/,""); print; exit}')"
if [[ -z "$pane" ]]; then
    echo "$prog: could not determine current pane" >&2
    exit 1
fi

out="$(cmux "$@")" || exit $?
surface="$(printf '%s\n' "$out" | sed -n 's/.*surface=\([^ ]*\).*/\1/p')"
if [[ -z "$surface" ]]; then
    echo "$prog: could not parse new surface from: $out" >&2
    exit 1
fi

cmux move-surface --surface "$surface" --pane "$pane" --focus true >/dev/null
